{
  "_doc": "Машинный канон секрет-паттернов для кода (MCP mm_secret_scan). Портирован из docs/SECRET-PATTERNS.md без изменений семантики. Док остаётся человекочитаемым источником; реконсиляция дока ↔ JSON — отдельный раунд. Класс A — высокоточные секреты; Класс B — широкие, warn-only.",
  "version": 1,
  "patterns": [
    {
      "id": "telegram-token",
      "description": "Telegram bot token (bot_id:hash, хэш 35 символов)",
      "class": "A",
      "regex": "[0-9]{5,16}:[A-Za-z0-9_-]{35}",
      "flags": "g",
      "source": "gitleaks telegram-bot-api-token"
    },
    {
      "id": "openai-key",
      "description": "OpenAI API keys (маркер T3BlbkFJ, вкл. project/service-account)",
      "class": "A",
      "regex": "sk-[A-Za-z0-9]{20}T3BlbkFJ[A-Za-z0-9]{20}|sk-(?:proj|svcacct|admin)-[A-Za-z0-9_-]{58,74}T3BlbkFJ[A-Za-z0-9_-]{58,74}",
      "flags": "g",
      "source": "gitleaks openai-api-key"
    },
    {
      "id": "anthropic-key",
      "description": "Anthropic API keys",
      "class": "A",
      "regex": "sk-ant-api03-[A-Za-z0-9_-]{93}AA",
      "flags": "g",
      "source": "gitleaks anthropic-api-key"
    },
    {
      "id": "github-token",
      "description": "GitHub tokens (ghp_/gho_/ghu_/ghs_/ghr_)",
      "class": "A",
      "regex": "gh[posru]_[0-9A-Za-z]{36}",
      "flags": "g",
      "source": "gitleaks github-pat/-oauth/-app-token/-refresh-token"
    },
    {
      "id": "aws-key",
      "description": "AWS access key ID (вкл. ASIA temp creds)",
      "class": "A",
      "regex": "(A3T[A-Z0-9]|AKIA|ASIA|ABIA|ACCA)[A-Z2-7]{16}",
      "flags": "g",
      "source": "gitleaks aws-access-token"
    },
    {
      "id": "aws-secret",
      "description": "AWS secret access key (40 base64 рядом с aws_secret)",
      "class": "A",
      "regex": "aws_secret[a-z_]*[\\s:=>\"']{0,5}[A-Za-z0-9/+]{40}",
      "flags": "gi",
      "source": "provider docs"
    },
    {
      "id": "slack-token",
      "description": "Slack tokens (bot / user / legacy)",
      "class": "A",
      "regex": "xoxb-[0-9]{10,13}-[0-9]{10,13}[A-Za-z0-9-]*|xox[pe](?:-[0-9]{10,13}){3}-[A-Za-z0-9-]{28,34}|xox[os]-\\d+-\\d+-\\d+-[a-fA-F\\d]+",
      "flags": "g",
      "source": "gitleaks slack-bot-token/-user-token/-legacy-token"
    },
    {
      "id": "google-key",
      "description": "Google / GCP API keys",
      "class": "A",
      "regex": "AIza[\\w-]{35}",
      "flags": "g",
      "source": "gitleaks gcp-api-key"
    },
    {
      "id": "google-oauth",
      "description": "Google OAuth tokens",
      "class": "A",
      "regex": "ya29\\.[A-Za-z0-9_-]+",
      "flags": "g",
      "source": "provider docs"
    },
    {
      "id": "jwt",
      "description": "JWT tokens (header.payload.signature)",
      "class": "A",
      "regex": "eyJ[A-Za-z0-9_-]{20,}\\.[A-Za-z0-9_-]{20,}\\.[A-Za-z0-9_-]{20,}",
      "flags": "g",
      "source": "RFC 7519"
    },
    {
      "id": "private-key",
      "description": "PEM приватный ключ (весь блок BEGIN…END)",
      "class": "A",
      "regex": "-----BEGIN[ A-Z0-9_-]{0,100}PRIVATE KEY( BLOCK)?-----[\\s\\S]{64,}?-----END[ A-Z0-9_-]{0,100}PRIVATE KEY( BLOCK)?-----",
      "flags": "g",
      "source": "gitleaks private-key"
    },
    {
      "id": "generic-secret",
      "description": "Именованные ключи + generic high-entropy assignment (api_key/token/secret = \"…\")",
      "class": "A",
      "regex": "(authorization|api[_-]?key|secret|password|passwd|token|bearer|credential|creds|private[_-]?key|signature|cookie)[\\s:=>\"']{1,5}[\\w.=/+-]{10,150}",
      "flags": "gi",
      "source": "gitleaks generic-api-key"
    },
    {
      "id": "url-creds",
      "description": "URL с inline credentials (user:pass@host)",
      "class": "A",
      "regex": "https?://[^\\s]*:[^@\\s/]+@",
      "flags": "g",
      "source": "context-mode"
    },
    {
      "id": "conn-string",
      "description": "Connection strings с паролем (Mongo / Postgres / Redis)",
      "class": "A",
      "regex": "(mongodb(\\+srv)?|postgres(ql)?|redis)://[^\\s/]+:[^@\\s/]+@",
      "flags": "g",
      "source": "context-mode"
    },
    {
      "id": "long-token",
      "description": "Длинные токены/хеши ≥32 символов с буквами и цифрами (git SHA, UUID, base64) — warn-only",
      "class": "B",
      "regex": "(?=[A-Za-z0-9_-]*[A-Za-z])(?=[A-Za-z0-9_-]*[0-9])[A-Za-z0-9_-]{32,}",
      "flags": "g",
      "source": "context-mode"
    }
  ]
}
